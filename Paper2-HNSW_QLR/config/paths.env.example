# =============================================================================
# toploc_paper_2 / config / paths.env.example
# -----------------------------------------------------------------------------
# COPY this file to paths.env and edit every value marked ``/path/to/...``
# to point at the actual location on your system:
#
#     cp config/paths.env.example config/paths.env
#     edit config/paths.env
#     ./VERIFY_CODE_PACKAGE.sh
#
# All shell wrappers source this file through config/load_config.sh; every
# Python producer reads the same environment variables via os.environ. No
# hard-coded paths remain in the executed code.
#
# The RUN_ALL.sh / VERIFY_CODE_PACKAGE.sh scripts fail loudly with the exact
# missing variable if a required item is not set.
#
# See manifests/EXTERNAL_RESOURCES.yaml for the expected format, dimensions,
# and approximate size of each external file.
# =============================================================================

# --- Python interpreters -----------------------------------------------------
# Hybrid track (FAISS 1.9, Python 3.11 miniforge env used to produce the frozen
#   full_20260717_043250_775324 artifacts).
HYBRID_PYTHON=/path/to/miniforge3/envs/toploc-cpp/bin/python

# Native faithful MS MARCO-v1 track (Python 3.10 conda env matching the .so ABI
#   cpython-310-x86_64-linux-gnu).
NATIVE_PYTHON=/path/to/anaconda3/envs/zeroec/bin/python

# General-purpose interpreter used by wrapper helpers (numpy-only; no faiss).
REPORT_PYTHON=/usr/bin/python3


# --- Hybrid TREC-CAsT track (Results 1, 5, 6) --------------------------------
# 158 GB FAISS HNSW document index built on the TREC-CAsT corpus (Snowflake
#   Arctic Embed L 1024-d, HNSW M=32). Not bundled.
HYBRID_DOC_INDEX=/path/to/indexes/HNSW_indexes/treccast_hnsw_M32.index

# Directory of parquet files with dev-query embeddings (id, embedding columns).
#   ~43 MB total (6980 dev queries).
DEV_QUERY_DIR=/path/to/HNSW/msmarco_snowflake/dev_query

# Router artefacts (query-log HNSW + PCA):
#   pca_1024_to_256.joblib   ~1 MB   sklearn.decomposition.PCA (mean_, components_)
#   train_query_pca256_hnsw.faiss ~1 GB  FAISS HNSW index over PCA-projected queries
#   qmax_pca256.npy          132 B   scalar float
PCA_QL_DIR=/path/to/HNSW/querylog_pca256

# Individual overrides (leave commented to fall back to PCA_QL_DIR/<name>).
#PCA_MODEL=${PCA_QL_DIR}/pca_1024_to_256.joblib
#ROUTER_INDEX=${PCA_QL_DIR}/train_query_pca256_hnsw.faiss
#PCA_QMAX=${PCA_QL_DIR}/qmax_pca256.npy

# QLR artefacts: EP table produced by Paper-2 Stage 3.
#   ep_indices.npy    ~32 MB  int32 (n_train_queries, K)
#   ep_distances.npy  ~32 MB  float32 (n_train_queries, K) (loaded for parity)
QLR_ARTIFACT_DIR=/path/to/HNSW/qlr_artifacts_full

# Exact-search reference top-10 for the 6980 dev queries (int32 ids).
#   exact_indices.npy   ~546 KB   (6980, 10)  int32
EXACT_DIR=/path/to/HNSW/exact_results_full


# --- Native faithful MS MARCO-v1 500k track (Results 2, 3, 4) ----------------
# Root of the faithful workspace (contains ground_truth/ and ep_table/).
#   ground_truth/dev_small_query_embs.npy     ~28 MB    float32 (N, 1024)
#   ground_truth/dev_small_exact_top10_ids.npy ~279 KB  int32   (N, 10)
#   ep_table/ep_scores.npy                    ~207 MB   float32 (n_train, K)
FAITH_ROOT=/path/to/faithful_msmarco_v1_20260719_042528

# Directory containing the native_qlr* .so files. Two supported values:
#   • NATIVE_MODULE_DIR=${SUBMISSION_CODE_PKG_ROOT}/native/prebuilt
#       — use the shipped cpython-310 x86-64 prebuilt binaries (fastest path).
#   • NATIVE_MODULE_DIR=${SUBMISSION_CODE_PKG_ROOT}/native/build
#       — after running build/BUILD_NATIVE.sh to compile from native/src/.
# The build helper writes here.
NATIVE_MODULE_DIR=${SUBMISSION_CODE_PKG_ROOT}/native/prebuilt

# Directory of the 4.2 GB native_export produced by the faithful pipeline.
#   Contains doc_vecs.f32 (2.0 GB), iq_vecs.f32 (830 MB), iq_vecs.f16 (415 MB),
#   pca_mean.f32, pca_components.f32, ep_ids.i32, dev_embs.f32, dev_gt_top10.i32
#   and their level-0 neighbour arrays. Not bundled.
NATIVE_EXPORT_DIR=/path/to/native_export


# --- Faithful adaptive-depth TREC-CAsT track (Experiment 7) ------------------
# Experiment 7 is the paper-faithful QLR (Algorithm 1) implementation with
# query-dependent adaptive HNSW search depth.  It shares the 158 GB doc index
# (HYBRID_DOC_INDEX) and the router HNSW index (ROUTER_INDEX / PCA_QL_DIR)
# with the hybrid track.  The only additional external requirement is a
# directory containing the two PCA arrays used by the faithful implementation.
#
# PCA arrays extracted from the paper training pipeline:
#   pca_mean_1024.npy         ~4 KB    float32 (1024,)
#   pca_components_256x1024.npy ~1 MB  float32 (256, 1024)
FAITHFUL_PCA_DIR=/path/to/faithful_pca_extracted

# Individual overrides (leave commented to fall back to FAITHFUL_PCA_DIR/<name>).
#FAITHFUL_PCA_MEAN=${FAITHFUL_PCA_DIR}/pca_mean_1024.npy
#FAITHFUL_PCA_COMPONENTS=${FAITHFUL_PCA_DIR}/pca_components_256x1024.npy

# Optional /dev/shm fast paths for the doc + router indexes.  If these files
# exist at run time they are preferred (mmap for /dev/shm doc index); if they
# do not exist the wrapper falls back to HYBRID_DOC_INDEX and ROUTER_INDEX.
# The wrapper does NOT create these — populate them yourself if you want the
# in-tmpfs fast path used on the reference machine.
#FAITHFUL_DOC_INDEX_SHM=/dev/shm/qlr_indexes/treccast_hnsw_M32.index
#FAITHFUL_QUERY_INDEX_SHM=/dev/shm/qlr_indexes/train_query_pca256_hnsw.faiss


# --- Preprocessing / artifact-generation (preprocessing/) --------------------
# Only needed if you regenerate benchmark artifacts via preprocessing/scripts/.
# The benchmarks themselves do NOT read these variables.
#
# Where regenerated artifacts are written (per-artifact subdirectories are
# created underneath: index_artifacts/, querylog_pca256/, qlr_artifacts_full/,
# exact_results_full/). Defaults to preprocessing/_generated/ if unset.
#PREPROC_OUTPUT_ROOT=${SUBMISSION_CODE_PKG_ROOT}/preprocessing/_generated

# Document embedding parquet shards (input to build_index.py). Columns [id, embedding].
PREPROC_DOC_EMB_DIR=/path/to/document_embeddings/snowflake

# Train / query-log embedding parquets (input to build_query_log_pca.py + build_ep_table.py).
PREPROC_TRAIN_QUERY_DIR=/path/to/train_query_embeddings/snowflake

# Exact flat index used to produce ground truth (input to flat_index_search_acc.py).
#   e.g. treccast_flat.index (a FAISS flat/IP index over the document corpus).
PREPROC_FLAT_INDEX=/path/to/Exact_Search/treccast_flat.index

# build_ep_table.py reuses HYBRID_DOC_INDEX (above); flat_index_search_acc.py
# reuses DEV_QUERY_DIR (above). No duplicate variables are introduced.


# --- Runtime output root -----------------------------------------------------
# Where each RUN.sh writes fresh timestamped output directories. Defaults to
# SUBMISSION_CODE_PKG_ROOT/outputs if unset.
#OUTPUT_ROOT=${SUBMISSION_CODE_PKG_ROOT}/outputs


# --- Benchmark CPU affinity --------------------------------------------------
# CPU core index that every wrapper pins to via ``taskset -c $CORE``.
# The frozen artefacts were produced on core 21. Change only if you know what
# you are doing — thermal characteristics of the physical core affect timings.
CORE=21
