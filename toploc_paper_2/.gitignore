# Machine-specific config (supervisor copies paths.env.example -> paths.env)
config/paths.env

# Runtime outputs
outputs/
!outputs/.gitkeep

# Native build products (regenerated by build/BUILD_NATIVE.sh)
native/build/

# Regenerated preprocessing artifacts (produced by preprocessing/scripts/)
preprocessing/_generated/
preprocessing/validation/*.log

# Regenerated archives (produced by the maintainer via VERIFY + tar/zip)
dist/
!dist/.gitkeep

# Fresh validation logs (per-machine reruns of VERIFY_CODE_PACKAGE.sh)
validation/*.log
validation/VERIFY_CODE_PACKAGE_*.log

# Python bytecode caches
__pycache__/
*.pyc
*.pyo

# Editor / OS metadata
.DS_Store
.vscode/
.idea/
*.swp
*.swo
